<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Apple Events: Sutando drives Chrome, Zoom, QuickTime, System Events,
         Finder, Mail, etc. via osascript-style scripting throughout
         inline-tools.ts and browser-tools.ts. -->
    <key>com.apple.security.automation.apple-events</key>
    <true/>

    <!-- Microphone: voice agent. Hardened-runtime requires the
         `audio-input` key; the `microphone` key is the sandbox-era name
         and macOS tccd will refuse to prompt without `audio-input`
         present. We keep both for forward/back compatibility. -->
    <key>com.apple.security.device.audio-input</key>
    <true/>
    <key>com.apple.security.device.microphone</key>
    <true/>

    <!-- Camera: optional, for meeting joins. -->
    <key>com.apple.security.device.camera</key>
    <true/>

    <!-- File access: the launcher reads/writes outside the bundle (the
         bundled repo is read-only, but state lives in
         ~/Library/Application Support/Sutando, and users drop files from
         arbitrary Finder paths). -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
    <key>com.apple.security.files.downloads.read-write</key>
    <true/>

    <!-- Network: the bundled services bind to localhost ports
         (8080, 9900, 7843–7846, 3100) and connect to Gemini/Twilio/Claude. -->
    <key>com.apple.security.network.client</key>
    <true/>
    <key>com.apple.security.network.server</key>
    <true/>

    <!-- Hardened runtime needs library validation off because we exec
         bundled Node + Python from Resources/runtime/, which load dylibs
         that are not signed by Apple or the same team. -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>

    <!-- Allow JIT for WKWebView's JavaScript engine in the in-app voice
         + dashboard windows. The Swift launcher itself doesn't JIT;
         bundled Node/V8 carries its own JIT entitlement via
         Sutando-runtime.entitlements (child processes don't inherit
         the parent's entitlements — they're baked in at codesign time).
         allow-unsigned-executable-memory is intentionally NOT on the
         outer .app — it's strictly weaker than allow-jit and triggers
         Apple's "in-depth analysis" path on notarization. The bundled
         binaries that actually need it have it via their own
         entitlements file. -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
</dict>
</plist>
